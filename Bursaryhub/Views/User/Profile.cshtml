@model BursaryHub.Models.User
@{ ViewData["Title"] = "My Profile"; }

<div class="row">
    <div class="col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-4">
                <div class="mb-3">
                    <i class="bi bi-person-circle text-primary" style="font-size:64px;"></i>
                </div>
                <h5 class="fw-bold">@Model.FullName</h5>
                <p class="text-muted small mb-3">@Model.Email</p>
                <span class="badge bg-primary mb-3">@Model.Role.RoleName</span>
                <p class="text-muted small mb-0">
                    <i class="bi bi-calendar me-1"></i>Member since @Model.CreatedDate.ToString("MMMM yyyy")
                </p>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header fw-bold bg-light">Account Information</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">First Name</dt><dd class="col-sm-9">@Model.FirstName</dd>
                    <dt class="col-sm-3">Last Name</dt><dd class="col-sm-9">@Model.LastName</dd>
                    <dt class="col-sm-3">Email</dt><dd class="col-sm-9">
                        @Model.Email
                        <span class="badge @(Model.IsEmailVerified ? "bg-success" : "bg-warning text-dark") ms-2">
                            @(Model.IsEmailVerified ? "✓ Verified" : "⚠ Not Verified")
                        </span>
                    </dd>
                    <dt class="col-sm-3">Phone</dt><dd class="col-sm-9">@Model.PhoneNumber</dd>
                    <dt class="col-sm-3">Last Login</dt><dd class="col-sm-9">@(Model.LastLoginDate?.ToString("dd MMM yyyy HH:mm") ?? "This is your first login")</dd>
                </dl>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header fw-bold bg-light">Security</div>
            <div class="card-body">
                <a class="btn btn-outline-primary" asp-controller="Account" asp-action="ChangePassword">
                    <i class="bi bi-key me-1"></i>Change Password
                </a>
            </div>
        </div>
    </div>
</div>
