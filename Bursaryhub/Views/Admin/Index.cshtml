@model BursaryHub.Models.ViewModels.AdminDashboardViewModel
@{ ViewData["Title"] = "Admin Dashboard"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-speedometer2 me-2 text-primary"></i>Admin Dashboard</h2>
    <form method="post" asp-action="RunScraper">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-warning"
                onclick="return confirm('Run the web scraper now? This may take a minute.')">
            <i class="bi bi-robot me-1"></i>Run Scraper
        </button>
    </form>
</div>

<!-- Stat Cards -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm text-white bg-primary">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-people-fill fs-1 me-3 opacity-75"></i>
                <div>
                    <div class="fs-2 fw-bold">@Model.TotalUsers</div>
                    <div class="small">Active Users</div>
                </div>
            </div>
            <a class="stretched-link" asp-action="Users"></a>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm text-white bg-success">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-bookmark-star-fill fs-1 me-3 opacity-75"></i>
                <div>
                    <div class="fs-2 fw-bold">@Model.TotalBursaries</div>
                    <div class="small">Active Bursaries</div>
                </div>
            </div>
            <a class="stretched-link" asp-controller="Bursary" asp-action="Manage"></a>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm text-white bg-info">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-send-fill fs-1 me-3 opacity-75"></i>
                <div>
                    <div class="fs-2 fw-bold">@Model.TotalApplications</div>
                    <div class="small">Total Applications</div>
                </div>
            </div>
            <a class="stretched-link" asp-action="Applications"></a>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm text-white bg-warning">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-hourglass-split fs-1 me-3 opacity-75"></i>
                <div>
                    <div class="fs-2 fw-bold">@Model.PendingApplications</div>
                    <div class="small">Pending Review</div>
                </div>
            </div>
            <a class="stretched-link" asp-action="Applications" asp-route-status="Pending"></a>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header fw-bold bg-light"><i class="bi bi-lightning-fill me-2 text-warning"></i>Quick Actions</div>
    <div class="card-body d-flex flex-wrap gap-2">
        <a class="btn btn-primary" asp-controller="Bursary" asp-action="Create"><i class="bi bi-plus-circle me-1"></i>Add Bursary</a>
        <a class="btn btn-secondary" asp-action="Users"><i class="bi bi-people me-1"></i>Manage Users</a>
        <a class="btn btn-info text-white" asp-action="Applications" asp-route-status="Pending"><i class="bi bi-eye me-1"></i>Review Pending</a>
        <a class="btn btn-success" asp-controller="Bursary" asp-action="Manage"><i class="bi bi-list-check me-1"></i>All Bursaries</a>
    </div>
</div>

<!-- Charts row -->
<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header fw-bold bg-light">Applications by Status</div>
            <div class="card-body"><canvas id="statusChart" height="200"></canvas></div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header fw-bold bg-light">Top Bursaries by Applications</div>
            <div class="card-body">
                <table class="table table-sm">
                    <thead><tr><th>Bursary</th><th class="text-end">Applications</th></tr></thead>
                    <tbody>
                        @foreach (var b in Model.TopBursaries)
                        {
                            <tr>
                                <td class="text-truncate" style="max-width:200px">@b.Name</td>
                                <td class="text-end"><span class="badge bg-primary">@b.ApplicationCount</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const statusData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ApplicationsByStatus));
const labels = Object.keys(statusData);
const values = Object.values(statusData);
const colors = {'Pending':'#ffc107','Approved':'#198754','Rejected':'#dc3545','Withdrawn':'#6c757d'};

new Chart(document.getElementById('statusChart'), {
    type: 'doughnut',
    data: {
        labels,
        datasets: [{ data: values, backgroundColor: labels.map(l => colors[l] || '#0d6efd') }]
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
});
</script>
}
