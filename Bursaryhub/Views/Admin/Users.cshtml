@model IEnumerable<BursaryHub.Models.User>
@{ ViewData["Title"] = "Manage Users"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="fw-bold"><i class="bi bi-people me-2 text-primary"></i>Users (@ViewBag.Total)</h3>
</div>

<!-- Search/Filter Bar -->
<form method="get" class="row g-2 mb-4">
    <div class="col-md-4">
        <input type="text" name="search" class="form-control" placeholder="Search name or email..." value="@ViewBag.Search" />
    </div>
    <div class="col-md-3">
        <select name="role" class="form-select">
            <option value="">All Roles</option>
            @foreach (var role in (List<BursaryHub.Models.Role>)ViewBag.Roles)
            {
                <option value="@role.RoleId">@role.RoleName</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="status" class="form-select">
            <option value="">All Status</option>
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i>Filter</button>
    </div>
</form>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th><th>Email</th><th>Role</th>
                    <th>Registered</th><th>Last Login</th><th>Status</th><th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td class="fw-semibold">@u.FullName</td>
                        <td>@u.Email</td>
                        <td><span class="badge @(u.Role.RoleName=="Admin"?"bg-danger":u.Role.RoleName=="Moderator"?"bg-warning text-dark":"bg-secondary")">@u.Role.RoleName</span></td>
                        <td class="small text-muted">@u.CreatedDate.ToString("dd MMM yyyy")</td>
                        <td class="small text-muted">@(u.LastLoginDate?.ToString("dd MMM yyyy HH:mm") ?? "Never")</td>
                        <td>
                            <span class="badge @(u.IsActive ? "bg-success" : "bg-secondary")">
                                @(u.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="EditUser" asp-route-id="@u.UserId" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-sm btn-outline-info" asp-action="UserDetails" asp-route-id="@u.UserId" title="View">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (u.IsActive)
                            {
                                <form method="post" asp-action="DeleteUser" asp-route-id="@u.UserId" class="d-inline"
                                      onsubmit="return confirm('Deactivate this user?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger" title="Deactivate"><i class="bi bi-person-x"></i></button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-action="ReactivateUser" asp-route-id="@u.UserId" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-success" title="Reactivate"><i class="bi bi-person-check"></i></button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Pagination -->
@{
    int page     = (int)ViewBag.Page;
    int pageSize = (int)ViewBag.PageSize;
    int total    = (int)ViewBag.Total;
    int pages    = (int)Math.Ceiling((double)total / pageSize);
}
@if (pages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= pages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Users" asp-route-page="@i"
                       asp-route-search="@ViewBag.Search">@i</a>
                </li>
            }
        </ul>
    </nav>
}
