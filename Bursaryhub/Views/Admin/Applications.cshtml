@model IEnumerable<BursaryHub.Models.BursaryApplication>
@{ ViewData["Title"] = "Applications"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="fw-bold"><i class="bi bi-send me-2 text-primary"></i>Applications (@ViewBag.Total)</h3>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-4">
        <input type="text" name="search" class="form-control" placeholder="Search student or bursary..." value="@ViewBag.Search" />
    </div>
    <div class="col-md-3">
        <select name="status" class="form-select">
            <option value="">All Statuses</option>
            @foreach (var s in new[]{"Pending","Approved","Rejected","Withdrawn"})
            {
                <option value="@s" selected="@(ViewBag.Status == s)">@s</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i>Filter</button>
    </div>
</form>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Student</th><th>Bursary</th><th>Date Applied</th>
                    <th>Status</th><th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td class="fw-semibold">@a.User.FullName</td>
                        <td>@a.Bursary.Name</td>
                        <td class="small text-muted">@a.ApplicationDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="badge @(a.Status=="Approved"?"bg-success":a.Status=="Rejected"?"bg-danger":a.Status=="Withdrawn"?"bg-secondary":"bg-warning text-dark")">
                                @a.Status
                            </span>
                        </td>
                        <td class="text-end">
                            @if (a.Status == "Pending")
                            {
                                <a class="btn btn-sm btn-primary" asp-action="ReviewApplication" asp-route-id="@a.ApplicationId">
                                    <i class="bi bi-clipboard-check me-1"></i>Review
                                </a>
                            }
                            else
                            {
                                <span class="text-muted small">Reviewed @a.ReviewedDate?.ToString("dd MMM")</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@{
    int page = (int)ViewBag.Page, pageSize = (int)ViewBag.PageSize, total = (int)ViewBag.Total;
    int pages = (int)Math.Ceiling((double)total / pageSize);
}
@if (pages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= pages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Applications" asp-route-page="@i"
                       asp-route-status="@ViewBag.Status" asp-route-search="@ViewBag.Search">@i</a>
                </li>
            }
        </ul>
    </nav>
}
