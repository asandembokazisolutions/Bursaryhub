@model BursaryHub.Models.ViewModels.BursaryFormViewModel
@{ ViewData["Title"] = "Add Bursary"; }

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h3 class="fw-bold mb-4"><i class="bi bi-plus-circle me-2 text-primary"></i>Add New Bursary</h3>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form method="post" asp-action="Create">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. National Merit Scholarship" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="4" 
                                  placeholder="Detailed description of the bursary..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Provider" class="form-label fw-semibold"></label>
                            <input asp-for="Provider" class="form-control" placeholder="e.g. National Merit Corp" />
                            <span asp-validation-for="Provider" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Amount" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">R</span>
                                <input asp-for="Amount" class="form-control" type="number" step="0.01" placeholder="10000" />
                            </div>
                            <span asp-validation-for="Amount" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ApplicationDeadline" class="form-label fw-semibold"></label>
                            <input asp-for="ApplicationDeadline" class="form-control" type="date" />
                            <span asp-validation-for="ApplicationDeadline" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="AwardDate" class="form-label fw-semibold"></label>
                            <input asp-for="AwardDate" class="form-control" type="date" />
                            <span asp-validation-for="AwardDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EligibilityCriteria" class="form-label fw-semibold"></label>
                        <input asp-for="EligibilityCriteria" class="form-control" 
                               placeholder="e.g. GPA 3.5+, South African citizens only" />
                        <span asp-validation-for="EligibilityCriteria" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ApplicationUrl" class="form-label fw-semibold"></label>
                        <input asp-for="ApplicationUrl" class="form-control" type="url"
                               placeholder="https://example.com/apply" />
                        <span asp-validation-for="ApplicationUrl" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check me-1"></i>Add Bursary
                        </button>
                        <a asp-action="Manage" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
