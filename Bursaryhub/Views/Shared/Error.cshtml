@{ ViewData["Title"] = "Error"; }

<div class="row justify-content-center py-5">
    <div class="col-md-6 text-center">
        <i class="bi bi-exclamation-triangle text-danger" style="font-size:48px;"></i>
        <h2 class="fw-bold mt-3">Oops! Something went wrong.</h2>
        <p class="text-muted mb-3">An unexpected error occurred while processing your request.</p>
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index"><i class="bi bi-house me-1"></i>Go Home</a>
    </div>
</div>
