@model BursaryHub.Models.ViewModels.ResetPasswordViewModel
@{ ViewData["Title"] = "Reset Password"; }

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h3 class="card-title fw-bold text-center mb-4"><i class="bi bi-lock me-2 text-primary"></i>Reset Password</h3>

                <form method="post" asp-action="ResetPassword">
                    @Html.AntiForgeryToken()
                    <input asp-for="Token" type="hidden" />
                    <input asp-for="Email" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                        <input asp-for="NewPassword" type="password" class="form-control" 
                               placeholder="New password (min 8 chars, upper, lower, digit, special)" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmNewPassword" class="form-label fw-semibold"></label>
                        <input asp-for="ConfirmNewPassword" type="password" class="form-control" placeholder="Repeat password" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">Reset Password</button>
                    </div>
                </form>

                <hr />
                <p class="text-center small mb-0"><a asp-action="Login" class="text-decoration-none">Back to Login</a></p>
            </div>
        </div>
    </div>
</div>
