@{ ViewData["Title"] = "Access Denied"; }

<div class="row justify-content-center py-5">
    <div class="col-md-6 text-center">
        <i class="bi bi-shield-lock text-warning" style="font-size:48px;"></i>
        <h2 class="fw-bold mt-3">Access Denied</h2>
        <p class="text-muted mb-3">You don't have permission to access this page.</p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="btn btn-primary" asp-controller="Home" asp-action="Index"><i class="bi bi-house me-1"></i>Go Home</a>
        }
        else
        {
            <a class="btn btn-primary" asp-controller="Account" asp-action="Login"><i class="bi bi-person me-1"></i>Login</a>
        }
    </div>
</div>
