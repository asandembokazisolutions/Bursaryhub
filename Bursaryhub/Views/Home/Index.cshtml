@model IEnumerable<BursaryHub.Models.Bursary>
@{ ViewData["Title"] = "Home"; }

<!-- Hero -->
<div class="p-5 mb-4 bg-primary text-white rounded-3 text-center">
    <div class="container-fluid py-3">
        <h1 class="display-5 fw-bold"><i class="bi bi-mortarboard-fill me-2"></i>Welcome to BursaryHub</h1>
        <p class="col-md-8 mx-auto fs-5">Discover thousands of bursaries and scholarships. Start your journey today.</p>
        <a class="btn btn-warning btn-lg" asp-controller="Bursary" asp-action="Index">
            <i class="bi bi-search me-1"></i>Browse Bursaries
        </a>
        @if (User.Identity?.IsAuthenticated != true)
        {
            <a class="btn btn-outline-light btn-lg ms-2" asp-controller="Account" asp-action="Register">Register Free</a>
        }
    </div>
</div>

<!-- Stats -->
<div class="row text-center mb-5">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body py-4">
                <i class="bi bi-search fs-1 text-primary"></i>
                <h4 class="mt-2 fw-bold">Discover</h4>
                <p class="text-muted">Search and filter bursaries by amount, deadline, and more.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body py-4">
                <i class="bi bi-send fs-1 text-success"></i>
                <h4 class="mt-2 fw-bold">Apply</h4>
                <p class="text-muted">Submit applications directly through our platform with one click.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body py-4">
                <i class="bi bi-trophy fs-1 text-warning"></i>
                <h4 class="mt-2 fw-bold">Succeed</h4>
                <p class="text-muted">Track your applications and get notified about decisions.</p>
            </div>
        </div>
    </div>
</div>

<!-- Featured Bursaries -->
<h3 class="fw-bold mb-3"><i class="bi bi-star-fill text-warning me-2"></i>Featured Bursaries</h3>
<div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
    @foreach (var b in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <span class="badge @(b.DaysUntilDeadline <= 7 ? "bg-danger" : "bg-success") mb-2">
                        @(b.DaysUntilDeadline == 0 ? "Closed" : b.DaysUntilDeadline <= 7 ? $"{b.DaysUntilDeadline}d left" : "Active")
                    </span>
                    <h5 class="card-title">@b.Name</h5>
                    <p class="text-muted small">@b.Provider</p>
                    <p class="fw-bold text-success fs-5">R @b.Amount.ToString("N0")</p>
                    <p class="card-text small text-truncate">@b.Description</p>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a class="btn btn-primary btn-sm" asp-controller="Bursary" asp-action="Details" asp-route-id="@b.BursaryId">
                        View Details <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    }
</div>
<div class="text-center">
    <a class="btn btn-outline-primary btn-lg" asp-controller="Bursary" asp-action="Index">See All Bursaries &rarr;</a>
</div>
