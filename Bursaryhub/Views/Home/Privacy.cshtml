@{ ViewData["Title"] = "Privacy Policy"; }

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h2 class="fw-bold mb-4">Privacy Policy</h2>

        <h5 class="fw-bold mt-4">1. Information We Collect</h5>
        <p>We collect information you provide directly:
        <ul>
            <li>Name, email, phone number (for registration)</li>
            <li>Password (securely hashed)</li>
            <li>Application notes and preferences</li>
        </ul>

        <h5 class="fw-bold mt-4">2. How We Use Your Information</h5>
        <p>Your information is used to:</p>
        <ul>
            <li>Manage your account and applications</li>
            <li>Send you important notifications</li>
            <li>Improve our service</li>
            <li>Comply with legal obligations</li>
        </ul>

        <h5 class="fw-bold mt-4">3. Security</h5>
        <p>We use industry-standard security measures including:</p>
        <ul>
            <li>HTTPS encryption</li>
            <li>PBKDF2 password hashing</li>
            <li>Secure database practices</li>
        </ul>

        <h5 class="fw-bold mt-4">4. Third-Party Services</h5>
        <p>We may share your information with bursary providers when you apply, and with email service providers for notifications.</p>

        <h5 class="fw-bold mt-4">5. Changes to This Policy</h5>
        <p>We reserve the right to update this privacy policy at any time. Changes are effective immediately upon posting.</p>

        <hr class="my-4" />
        <p class="text-muted small">Last updated: January 2025</p>
    </div>
</div>
